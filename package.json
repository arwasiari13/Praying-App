{
  "name": "praying-app",
  "productName": "Praying App",
  "version": "1.0.0",
  "description": "Desktop app to track your daily prayers and progress",
  "main": "main.js",
  "author": "arwasiari13",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.arwasiari13.prayingapp",
    "productName": "Praying App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "PrayingApp-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "PrayingApp-Portable-${version}.${ext}"
    }
  }
}
